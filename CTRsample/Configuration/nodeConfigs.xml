<?xml version="1.0" encoding="UTF-8"?>
<SystemConfig>

    <!-- NETWORK / SYSTEM-WIDE SETTINGS -->
    <Network>
        <WebSocketPort>8080</WebSocketPort>
        <BroadcastRate_Hz>100</BroadcastRate_Hz>
    </Network>

    <!-- CTR NODE -->
    <CTRNode>
        <RefDes>CTR001</RefDes>
        <IP>localhost</IP>
        <Description>Central control and routing node</Description>
        <Enabled>true</Enabled>
    </CTRNode>

    <!-- DAQ NODES -->
    <DAQNodes>

        <DAQNode>
            <RefDes>DAQ000</RefDes>
            <IP>localhost</IP>
            <Description>Testing DAQ node</Description>
            <Enabled>true</Enabled>

            <Modules>

                <!-- 4-ch, 0-20mA analog current output -->
                <Module>
                    <SlotID>1</SlotID>
                    <ModelNumber>NI-9265</ModelNumber>
                    <Description>4-ch analog current output</Description>
                    <Enabled>true</Enabled>
                    <SampleRate_Hz>1000</SampleRate_Hz>
                    <Sensors>

                        <Sensor>
                            <RefDes>WV-01-POS</RefDes>
                            <SerialNumber>SN-00001</SerialNumber>
                            <ModelNumber>VALWORX-CV-4-20MA</ModelNumber>
                            <Type>ControlValve</Type>
                            <Channel>AO0</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>1.0</Sensitivity>
                            <SensitivityUnits>mA/%</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>mA</Units>
                        </Sensor>

                        <Sensor>
                            <RefDes>WV-02-POS</RefDes>
                            <SerialNumber>SN-00002</SerialNumber>
                            <ModelNumber>SHARPE-CV-4-20MA</ModelNumber>
                            <Type>ControlValve</Type>
                            <Channel>AO1</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>1.0</Sensitivity>
                            <SensitivityUnits>mA/%</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>mA</Units>
                        </Sensor>

                    </Sensors>
                </Module>

                <!-- 16-ch, +/-20mA analog current input -->
                <Module>
                    <SlotID>2</SlotID>
                    <ModelNumber>NI-9208</ModelNumber>
                    <Description>16-ch analog current input</Description>
                    <Enabled>true</Enabled>
                    <SampleRate_Hz>100</SampleRate_Hz>
                    <Sensors>

                        <Sensor>
                            <RefDes>WPT-01</RefDes>
                            <SerialNumber>SN-00003</SerialNumber>
                            <ModelNumber>OMEGA-PX119-150AI</ModelNumber>
                            <Type>PressureTransducer</Type>
                            <Channel>CH0</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>1.6</Sensitivity>
                            <SensitivityUnits>mA/psi</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>psi</Units>
                            <AbsolutePressure>true</AbsolutePressure>
                        </Sensor>

                        <Sensor>
                            <RefDes>WPT-02</RefDes>
                            <SerialNumber>SN-00004</SerialNumber>
                            <ModelNumber>OMEGA-PX119-150AI</ModelNumber>
                            <Type>PressureTransducer</Type>
                            <Channel>CH1</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>1.6</Sensitivity>
                            <SensitivityUnits>mA/psi</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>psi</Units>
                            <AbsolutePressure>true</AbsolutePressure>
                        </Sensor>

                        <Sensor>
                            <RefDes>WFM-01</RefDes>
                            <SerialNumber>SN-00005</SerialNumber>
                            <ModelNumber>OMEGA-FMA-1700</ModelNumber>
                            <Type>FlowMeter</Type>
                            <Channel>CH2</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>0.625</Sensitivity>
                            <SensitivityUnits>mA/GPM</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>GPM</Units>
                        </Sensor>

                        <Sensor>
                            <RefDes>WV-01-FB</RefDes>
                            <SerialNumber>SN-00006</SerialNumber>
                            <ModelNumber>VALWORX-CV-4-20MA</ModelNumber>
                            <Type>ValvePositionFeedback</Type>
                            <Channel>CH3</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>1.0</Sensitivity>
                            <SensitivityUnits>mA/%</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>%</Units>
                        </Sensor>

                        <Sensor>
                            <RefDes>WV-02-FB</RefDes>
                            <SerialNumber>SN-00007</SerialNumber>
                            <ModelNumber>SHARPE-CV-4-20MA</ModelNumber>
                            <Type>ValvePositionFeedback</Type>
                            <Channel>CH4</Channel>
                            <Enabled>true</Enabled>
                            <Sensitivity>1.0</Sensitivity>
                            <SensitivityUnits>mA/%</SensitivityUnits>
                            <CalibrationBalance>0.0</CalibrationBalance>
                            <CalibrationBalanceUnits>mA</CalibrationBalanceUnits>
                            <Units>%</Units>
                        </Sensor>

                    </Sensors>
                </Module>

                <!-- 8-ch, 5-30V sourcing digital output -->
                <Module>
                    <SlotID>3</SlotID>
                    <ModelNumber>NI-9474</ModelNumber>
                    <Description>8-ch sourcing digital output</Description>
                    <Enabled>true</Enabled>
                    <SampleRate_Hz>1000</SampleRate_Hz>
                    <Sensors>

                        <Sensor>
                            <RefDes>SOL001</RefDes>
                            <SerialNumber>SN-00007</SerialNumber>
                            <ModelNumber>GENERIC-SOL-24V</ModelNumber>
                            <Type>Solenoid</Type>
                            <Channel>DO0</Channel>
                            <Enabled>true</Enabled>
                            <Units>bool</Units>
                        </Sensor>

                        <Sensor>
                            <RefDes>SOL002</RefDes>
                            <SerialNumber>SN-00008</SerialNumber>
                            <ModelNumber>GENERIC-SOL-24V</ModelNumber>
                            <Type>Solenoid</Type>
                            <Channel>DO1</Channel>
                            <Enabled>true</Enabled>
                            <Units>bool</Units>
                        </Sensor>

                    </Sensors>
                </Module>

            </Modules>
        </DAQNode>

    </DAQNodes>

</SystemConfig>
