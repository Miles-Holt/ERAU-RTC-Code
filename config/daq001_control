state: safe {
    sequence: {
        //something that stops the makes valve released false for all commandable channels
        t: 0.0 {
            nv-01-pos = false
            nv-01-neg = false
            nv-02-pos = false
            nv-02-neg = false
        }
        t: 1.0 {//seconds
            ov-01-cmd = true
            fv-01-cmd = true
        }
    },
    control: {
        if targetState == "manualControl" {
            switch manualControl
        }
    }
}
state: manualControl {
    sequence: {
        //something that "releases all valve commands to the operator
    }
    control:{
        if targetState == "autoSequence" {
            switch autoSequence
        }
        if targetState == "safe" {
            switch safe
        }
    }
}
state: autoSequence {
    sequence: {
        //auto sequence of valves as specified by the user through webClient or already in a config file
    }
    control: {
        if (cpt > highChamberPressureAbortThreshold) || ((cpt < lowChamberPressureAbortThreshold) && (t > lowChamberPressureAbortTimeThreshold)) {
            switch abort
        }
        if targetState == "manualControl" {
            switch abort
        }
        if targetState == "safe" {
            switch safe
        }
    }
}